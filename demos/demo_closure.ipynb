   "source": [
    "# Démo Closure"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "64de7a9e-5b63-40d2-a97d-ccd6144ef361",
   "metadata": {},
   "outputs": [],
   "source": [
    "def counter():\n",
    "    count = 0\n",
    "    def inner():\n",
    "        nonlocal count\n",
    "        count += 1\n",
    "\n",
    "    def get_count():\n",
    "        return count\n",
    "\n",
    "    inner.get_count = get_count\n",
    "\n",
    "    return inner"
   ]
  }
